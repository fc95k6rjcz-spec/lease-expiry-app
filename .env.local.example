# Copy to .env.local and fill in from Supabase → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# SERVICE ROLE key — keep secret, never expose to the browser, never commit.
# Only used by the one-off bulk import script (scripts/import_cityscope.mjs).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Gemini (server-side only) — powers the camera scanner (app/api/ocr) and the
# AI opener generator (app/api/opener). Set these on Vercel, not in the browser.
GEMINI_API_KEY=your-gemini-api-key
# Model used by both routes. Must be a CURRENT model or the API returns 404.
# Good values: gemini-2.5-flash (default) or gemini-3.5-flash. Use
# gemini-flash-latest to always track Google's newest flash model.
# NOTE: the gemini-2.0-* line was shut down by Google in June 2026.
GEMINI_MODEL=gemini-2.5-flash
# Optional: override the model for the vision/scanner route only.
GEMINI_VISION_MODEL=gemini-2.5-flash
# Ask LEX chat uses the smartest model. Defaults to gemini-3.5-flash (stable
# flagship, best for grounded + tool-call work). Set to gemini-3.1-pro-preview
# for max research-grade reasoning (slower, pricier, preview).
GEMINI_CHAT_MODEL=gemini-3.5-flash
