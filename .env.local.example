# Copy to .env.local and fill in from Supabase → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Only needed for the one-off bulk import script (scripts/import_cityscope.mjs).
# This is the SERVICE ROLE key — keep it secret, never expose to the browser,
# never commit it. Not used by the app at runtime.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
