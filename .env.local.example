# Copy to .env.local and fill in from Supabase → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# SERVICE ROLE key — keep secret, never expose to the browser, never commit.
# Only used by the one-off bulk import script (scripts/import_cityscope.mjs).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Gemini (server-side only) — powers the camera scanner (app/api/ocr) and the
# AI opener generator (app/api/opener). Set these on Vercel, not in the browser.
GEMINI_API_KEY=your-gemini-api-key
# Model used by both routes. Must be a CURRENT model or the API returns 404.
# Good values: gemini-2.0-flash (default) or gemini-2.5-flash.
# Retired names like gemini-pro-vision / gemini-1.5-flash / gemini-pro will 404.
GEMINI_MODEL=gemini-2.0-flash
# Optional: override the model for the vision/scanner route only.
GEMINI_VISION_MODEL=gemini-2.0-flash
