# Copy to .env.local and fill in from Supabase → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# SERVICE ROLE key — keep secret, never expose to the browser, never commit.
# Used by the import script AND the billing API routes (server-side only).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ---- Stripe billing (server-side; set these in Vercel too) ----
STRIPE_SECRET_KEY=sk_live_or_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx           # from the webhook endpoint you create
STRIPE_PRICE_MONTHLY=price_xxx            # recurring monthly price id
STRIPE_PRICE_YEARLY=price_xxx             # recurring yearly price id
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app   # used for Checkout redirects
